# Copie ce fichier en .env.test et remplis les valeurs
# NE JAMAIS committer .env.test — il est dans .gitignore

# URL du projet Supabase (même valeur que VITE_SUPABASE_URL dans .env.local)
SUPABASE_URL=https://XXXXXXXXXXXXXXXX.supabase.co

# Clé ANON (publique) — sert à simuler un vrai utilisateur
SUPABASE_ANON_KEY=eyJhb...

# Clé SERVICE ROLE (secrète) — sert à insérer/supprimer les données de test
# Disponible dans : Supabase > Project Settings > API > service_role
SUPABASE_SERVICE_ROLE_KEY=eyJhb...
